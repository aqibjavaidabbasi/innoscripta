{
   "compilerOptions": {
      "jsx": "react",
      "module": "esnext",
      "moduleResolution": "node",
      "target": "esnext",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true,
      "allowJs": true,
      "lib": [
         "DOM",
         "ESNext"
      ]
   },
   "include": [
      "src"
   ]
}